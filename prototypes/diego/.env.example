# TTSTT Prototype — copy to `.env` in this directory (`prototypes/diego/.env`).
# `.env` is gitignored; never commit real tokens or keys to the public repo.
# If a secret was ever committed, rotate it in Azure Portal and the Discord Developer Portal.

# --- Discord bot (Azure TTS) ---
# Discord Application → Bot → token
DISCORD_BOT_TOKEN=
# Optional: your test server ID so slash commands sync quickly (omit for global-only sync)
DISCORD_GUILD_ID=
# Azure AI Services Speech resource (key + region from Azure Portal)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Neural voice short name, e.g. en-US-JennyNeural (see Azure "Text to speech voices" list)
AZURE_TTS_VOICE=en-US-JennyNeural
